# iClassPro Credentials
# Copy this file to .env and fill in your actual credentials
# IMPORTANT: Never commit .env to version control!

ICLASS_EMAIL=your@email.com
ICLASS_PASSWORD=yourpassword
ICLASS_STUDENT_ID=12345

# Optional: Promo code for discounts
# ICLASS_PROMO_CODE=YOURPROMOCODE

# Optional: Custom schedule file
# ICLASS_SCHEDULE=schedules/my_custom_schedule.json

# Optional: Complete transaction (CAUTION: Set to 1/true to actually pay for classes)
# ICLASS_COMPLETE_TRANSACTION=0

# Optional: Save screenshots during execution
# ICLASS_SAVE_SCREENSHOTS=0

# --- Email Notification Settings ---
# Set to 1/true to send a log of the run to your email
# ICLASS_SEND_EMAIL=0

# The SMTP server for your email provider (e.g., "smtp.gmail.com")
# ICLASS_SMTP_SERVER=

# The port for the SMTP server (usually 587 for TLS or 465 for SSL)
# ICLASS_SMTP_PORT=587

# IMPORTANT: This is NOT your regular email password.
# This must be an "App Password" generated from your email account settings.
# See your provider's help docs for "generating an app password".
# ICLASS_EMAIL_APP_PASSWORD=
