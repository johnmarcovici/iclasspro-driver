# Cloud Deployment Environment Variables
# Copy to Secret Manager in Google Cloud

# Database connection (Cloud SQL PostgreSQL)
# Format: postgresql://user:password@host:5432/dbname
# Use Cloud SQL Auth proxy or private connector
DATABASE_URL=postgresql://user:password@cloud-sql-host:5432/iclasspro_db

# Session security - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_SESSION_SECRET=<GENERATE_NEW_SECRET>

# Encryption key for storing passwords - Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<GENERATE_NEW_SECRET>

# Security settings for production
COOKIE_SECURE=1

# Concurrency configuration
MAX_CONCURRENT_JOBS=5
MAX_JOBS_PER_USER=3

# Environment marker
ENVIRONMENT=production

# Cloud-specific settings
GOOGLE_CLOUD_PROJECT=<YOUR_PROJECT_ID>
